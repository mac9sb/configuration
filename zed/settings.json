{
  "ui_font_family": "Liga SFMono Nerd Font",
  "git_panel": {
    "default_width": 320,
  },
  "agent": {
    "default_model": {
      "provider": "openrouter",
      "model": "openrouter/free",
      "enable_thinking": true,
    },
    "default_width": 340,
    "commit_message_model": {
      "provider": "openrouter",
      "model": "openrouter/free",
    },
    "inline_assistant_model": {
      "provider": "google",
      "model": "gemini-2.5-flash",
    },
  },
  "buffer_font_family": "Liga SFMono Nerd Font",
  "buffer_font_size": 11,
  "current_line_highlight": "all",
  "languages": {
    "Ruby": {
      "language_servers": ["!solargraph"],
    },
  },
  "minimap": {
    "show": "never",
  },
  "outline_panel": {
    "dock": "right",
  },
  "relative_line_numbers": "enabled",
  "restore_on_startup": "launchpad",
  "ssh_connections": [
    {
      "host": "dav.internal",
      "projects": [
        {
          "paths": ["/nfs/data/mac/data-migration-py"],
        },
      ],
    },
  ],
  "theme": {
    "mode": "system",
    "light": "Dayfox - blurred",
    "dark": "Nightfox - blurred",
  },
  "ui_font_size": 12.5,
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "never",
  },
  "which_key": {
    "enabled": true,
    "delay_ms": 200,
  },
}
