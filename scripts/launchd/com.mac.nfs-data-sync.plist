<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.mac.nfs-data-sync</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/sh</string>
		<string>/Users/mac/Developer/configuration/scripts/sync.sh</string>
	</array>
	<key>EnvironmentVariables</key>
	<dict>
		<key>PATH</key>
		<string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
	</dict>
	<key>WatchPaths</key>
	<array>
		<string>/Users/mac/Work/nfs-data-mac</string>
	</array>
	<key>ThrottleInterval</key>
	<integer>5</integer>
	<key>StandardOutPath</key>
	<string>/tmp/nfs-data-mac-sync.log</string>
	<key>StandardErrorPath</key>
	<string>/tmp/nfs-data-mac-sync.log</string>
	<key>RunAtLoad</key>
	<false/>
</dict>
</plist>
